{
  "commit_body_format": {
    "required_fields": ["what", "why"],
    "pattern": "^what: .+\\nwhy:  .+$"
  },
  "allowed_attribution_trailers": [
    "signed-off-by",
    "reviewed-by",
    "tested-by",
    "suggested-by",
    "co-authored-by",
    "helped-by"
  ],
  "portability": {
    "allow_platform_ref": true
  },
  "sync_targets": ["skills/repo-health-and-sync-skill/"]
}