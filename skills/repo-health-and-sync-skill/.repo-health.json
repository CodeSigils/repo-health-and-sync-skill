{
  "version": 1,
  "description": "Repository health configuration for repo-health-and-sync-skill",
  "commit_body_format": {
    "required_fields": ["what", "why"],
    "pattern": "^what: .+\\nwhy:  .+$"
  },
  "allowed_attribution_trailers": [
    "signed-off-by",
    "reviewed-by",
    "tested-by",
    "suggested-by"
  ],
  "portability": {
    "allow_platform_ref": true
  }
}
